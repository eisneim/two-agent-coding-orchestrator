#!/usr/bin/env python3
"""
orch-tail-log — Print the last N lines of .orch/dev_log.md.

The worker writes its progress here; orchestrator reads it to detect
completion signals like `[T3 DONE]`.

Usage:
    orch-tail-log               # last 20 lines
    orch-tail-log 50            # last 50 lines
    orch-tail-log --path PATH   # custom path (default: ./.orch/dev_log.md)

Exits with 0 even if the file is missing (silent).
"""

import argparse
import os
import sys


def main(argv):
    p = argparse.ArgumentParser(prog="orch-tail-log")
    p.add_argument("n", nargs="?", type=int, default=20)
    p.add_argument("--path", default=".orch/dev_log.md")
    args = p.parse_args(argv[1:])

    if not os.path.exists(args.path):
        return 0
    with open(args.path, encoding="utf-8") as f:
        lines = f.read().splitlines()
    out = lines[-args.n:] if args.n > 0 else lines
    sys.stdout.write("\n".join(out))
    if out:
        sys.stdout.write("\n")
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv))
