#!/usr/bin/env python3
"""
orch-retry — Recover a worker stuck on a transient API error.

When Claude hits a 424 / network / generic API error, it prints the
error message and waits for the user to press Enter to retry the same
turn. This script automates that:
  1. Verify state is IDLE and error_detected is non-null
  2. Send a single Enter
  3. Wait briefly, confirm state turned BUSY (or error cleared)
  4. Append a record to .orch/error-history.log

Optional cool-off: if more than --max-per-window retries have occurred
in the last --window seconds, refuse and exit with code 4 so the
orchestrator can escalate.

Usage:
    orch-retry <target> [--window 600] [--max-per-window 3]

Exit codes:
    0  retry sent successfully (state observed BUSY OR error cleared)
    2  precondition not met (no error detected, or worker is BUSY)
    3  retry sent but worker did not flip BUSY (unknown failure mode)
    4  rate-limited by cool-off; orchestrator should escalate
"""

import argparse
import datetime as dt
import json
import os
import subprocess
import sys
import time

HERE = os.path.dirname(os.path.abspath(__file__))
ORCH_STATUS = os.path.join(HERE, "orch-status")
ERR_LOG_DEFAULT = ".orch/error-history.log"


def status(target):
    out = subprocess.run(
        [ORCH_STATUS, target], check=True, capture_output=True, text=True
    )
    return json.loads(out.stdout)


def tmux_send_enter(target):
    subprocess.run(["tmux", "send-keys", "-t", target, "Enter"], check=True)


def recent_retry_count(log_path, window_s):
    if not os.path.exists(log_path):
        return 0
    cutoff = dt.datetime.now() - dt.timedelta(seconds=window_s)
    n = 0
    try:
        with open(log_path, encoding="utf-8") as f:
            for line in f:
                # format: ISO_TIMESTAMP\tTARGET\tERROR\tOUTCOME
                parts = line.rstrip("\n").split("\t", 3)
                if len(parts) < 1:
                    continue
                try:
                    ts = dt.datetime.fromisoformat(parts[0])
                except ValueError:
                    continue
                if ts >= cutoff:
                    n += 1
    except OSError:
        return 0
    return n


def append_log(log_path, target, err, outcome):
    os.makedirs(os.path.dirname(log_path), exist_ok=True)
    with open(log_path, "a", encoding="utf-8") as f:
        f.write(
            f"{dt.datetime.now().isoformat(timespec='seconds')}\t{target}\t{err}\t{outcome}\n"
        )


def main(argv):
    p = argparse.ArgumentParser(prog="orch-retry")
    p.add_argument("target")
    p.add_argument("--window", type=int, default=600,
                   help="cool-off window in seconds (default 600)")
    p.add_argument("--max-per-window", type=int, default=3,
                   help="max retries per window (default 3)")
    p.add_argument("--log", default=ERR_LOG_DEFAULT,
                   help="path to retry log (default .orch/error-history.log)")
    args = p.parse_args(argv[1:])

    pre = status(args.target)
    err = pre.get("error_detected")
    if not err:
        print(json.dumps({
            "ok": False,
            "error": "no_error_detected",
            "state": pre["state"],
        }))
        sys.exit(2)
    if pre["state"] == "BUSY":
        print(json.dumps({
            "ok": False,
            "error": "still_busy",
            "detail": "worker hasn't surfaced the error to the prompt yet",
        }))
        sys.exit(2)

    n_recent = recent_retry_count(args.log, args.window)
    if n_recent >= args.max_per_window:
        append_log(args.log, args.target, err, "RATE_LIMITED")
        print(json.dumps({
            "ok": False,
            "error": "rate_limited",
            "recent_retries": n_recent,
            "window_s": args.window,
            "advice": "escalate to user; auto-retry cooled off",
        }))
        sys.exit(4)

    # Send Enter
    tmux_send_enter(args.target)

    # Verify within ~5s either: state→BUSY, or error cleared
    success = False
    for _ in range(10):  # 5s
        time.sleep(0.5)
        st = status(args.target)
        if st["state"] == "BUSY":
            success = True
            break
        if st.get("error_detected") is None and st["state"] == "IDLE":
            # Error cleared but no busy — possibly the retry succeeded
            # instantly or Claude's auto-recover finished. Still call it ok.
            success = True
            break

    outcome = "RETRY_OK" if success else "RETRY_NO_RESPONSE"
    append_log(args.log, args.target, err, outcome)

    print(json.dumps({
        "ok": success,
        "error_was": err,
        "outcome": outcome,
        "recent_retries": n_recent + 1,
    }))
    sys.exit(0 if success else 3)


if __name__ == "__main__":
    main(sys.argv)
